# Claude Memory Local Configuration
# Copy this file to .env and adjust values as needed
# IMPORTANT: Never commit .env to version control!

# ===========================================
# PostgreSQL Database (Homebrew)
# ===========================================
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=claude_memory
PG_USER=claude
# SECURITY: Generate a strong password using: openssl rand -base64 32
PG_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ===========================================
# Ollama (Local Embeddings)
# SECURITY: Only localhost is allowed to prevent SSRF
# ===========================================
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Alternative embedding models:
# - all-minilm (384 dims, smaller/faster)
# - mxbai-embed-large (1024 dims, more accurate)

# ===========================================
# API Server Security
# ===========================================
# SECURITY: Bind to localhost only (use reverse proxy for external access)
API_HOST=127.0.0.1
API_PORT=8080

# SECURITY: API Key authentication (recommended for production)
# Generate with: openssl rand -hex 32
# API_KEY=your_api_key_here

# SECURITY: CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# SECURITY: Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# SECURITY: Disable API docs in production
# DISABLE_DOCS=true

# ===========================================
# Team Mode (Future)
# ===========================================
# TEAM_ID=my-team
# SYNC_SERVER_URL=https://sync.example.com
# USER_ID=user@example.com

# ===========================================
# Advanced Options
# ===========================================
# LOG_LEVEL=INFO
# MAX_MEMORIES_PER_QUERY=10
# MIN_SIMILARITY_THRESHOLD=0.5
# CONTEXT_INJECTION_ENABLED=true
# AUTO_CLEANUP_DAYS=180

# ===========================================
# ACT-R Cognitive Scoring
# Based on Honda et al. (HAI '25) - Human-Like Memory for LLM Agents
# ===========================================
# Enable/disable ACT-R scoring (false = original cosine*importance scoring)
USE_ACTR_SCORING=true

# Decay parameter (power-law forgetting rate, higher = faster decay)
ACTR_DECAY_D=0.5

# Semantic weight (cosine similarity multiplier, higher = more weight on meaning)
ACTR_WEIGHT_W=11.0

# Noise standard deviation (Gaussian variability, 0 = deterministic)
ACTR_NOISE_SIGMA=1.2

# Retrieval threshold (memories below this are filtered out)
ACTR_THRESHOLD_TAU=-2.0

# Spreading activation strength (associative boost via shared tags)
ACTR_SPREADING_S=2.0

# Enable spreading activation (tag-based associative boost)
ACTR_USE_SPREADING=true

# Enable Gaussian noise (probabilistic recall variability)
ACTR_USE_NOISE=true

# Number of candidates for pre-filtering before ACT-R re-ranking
ACTR_PREFETCH_LIMIT=50

# Forgetting cycle schedule (manual = via MCP tool only)
ACTR_FORGETTING_SCHEDULE=manual
